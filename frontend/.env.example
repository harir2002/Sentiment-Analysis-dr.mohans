# Frontend (Vercel) — copy to Project → Settings → Environment Variables

# Backend API (Hugging Face Space URL + /api if proxied, or direct Space URL)
VITE_API_URL=https://your-username-your-space.hf.space

# Must match backend ADMIN_USERNAME / ADMIN_PASSWORD
VITE_ADMIN_USERNAME=admin
VITE_ADMIN_PASSWORD=change-me-in-production
