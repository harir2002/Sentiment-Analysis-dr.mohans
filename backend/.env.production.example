# ============ APPLICATION ============
APP_ENV=production
LOG_LEVEL=INFO
LOG_FORMAT=json
EXPOSE_ERROR_DETAILS=false
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-in-production

# ============ DATABASE (Supabase Postgres — required for HF Spaces) ============
# Project Settings → Database → Connection string (URI)
# Use port 6543 + ?pgbouncer=true for transaction pooler, or 5432 direct.
DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true

# ============ STORAGE (Supabase Storage — recommended for file uploads) ============
STORAGE_BACKEND=s3
S3_ENDPOINT_URL=https://[PROJECT_REF].supabase.co/storage/v1/s3
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=call-analytics
S3_REGION=us-east-1

# Ephemeral local paths (container temp only — not durable)
UPLOAD_DIR=/tmp/call-analytics/uploads
TEMP_DIR=/tmp/call-analytics/tmp
CLEANUP_AUDIO_AFTER_JOB=true

# ============ CORS (Vercel frontend) ============
CORS_ORIGINS=https://your-app.vercel.app,http://localhost:5173

# ============ AI PROVIDERS ============
SARVAM_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=
