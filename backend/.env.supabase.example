# Supabase Postgres — copy to backend/.env for local development against Supabase
#
# 1. Create a project at https://supabase.com
# 2. Project Settings → Database → Connection string (URI)
# 3. Run: python -m scripts.setup_supabase_db
# 4. (Optional) python -m scripts.migrate_sqlite_to_supabase

APP_ENV=development

# Required — Supabase Postgres connection string
# Pooler (recommended for app): port 6543 + ?pgbouncer=true
DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[YOUR_PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true

# Optional — project metadata (not used for SQLAlchemy connection)
SUPABASE_URL=https://[PROJECT_REF].supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Local file storage is fine when developing against Supabase DB only
STORAGE_BACKEND=local
UPLOAD_DIR=./data/uploads
TEMP_DIR=./data/tmp

ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme
CORS_ORIGINS=http://localhost:5173

# AI provider keys (required for analysis)
SARVAM_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=
