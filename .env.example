# Application
APP_ENV=development
LOG_LEVEL=INFO
LOG_FORMAT=text
EXPOSE_ERROR_DETAILS=false
METRICS_ENABLED=true
SLOW_REQUEST_THRESHOLD_MS=5000
REQUEST_ID_HEADER=X-Request-ID
SQL_ECHO=false
ACCESS_LOG=true
API_MAX_RETRIES=3
API_RETRY_BASE_SECONDS=1.0
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# ============ DATABASE (Supabase Postgres) ============
# Primary persistence for production and pre-deploy testing.
# Copy backend/.env.supabase.example for a full Supabase-local template.

# Local SQLite fallback (only when DATABASE_URL is not Postgres):
DATABASE_URL=sqlite+aiosqlite:///./data/app.db

# Supabase Postgres (uncomment and fill — see docs/SUPABASE-MIGRATION.md):
# DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true

# Optional Supabase project metadata (DATABASE_URL is the required connection)
# SUPABASE_URL=https://[PROJECT_REF].supabase.co
# SUPABASE_SERVICE_ROLE_KEY=

# ============ STORAGE ============
# "local" = development only. "s3" = Supabase Storage (production uploads).
STORAGE_BACKEND=local

UPLOAD_DIR=./data/uploads
TEMP_DIR=./data/tmp

# S3-compatible storage (Supabase Storage or AWS S3)
# S3_ENDPOINT_URL=https://PROJECT_ID.supabase.co/storage/v1/s3
# S3_ACCESS_KEY_ID=your_access_key
# S3_SECRET_ACCESS_KEY=your_secret_key
# S3_BUCKET=call-analytics
# S3_REGION=us-east-1

# File upload limits
MAX_UPLOAD_SIZE_MB=25
MIN_SAMPLE_RATE_HZ=8000
MAX_SAMPLE_RATE_HZ=48000
CLEANUP_AUDIO_AFTER_JOB=true

# ============ JOB PROCESSING ============
JOB_WORKER_ENABLED=true
JOB_WORKER_POLL_INTERVAL=5.0
JOB_WORKER_MAX_CONCURRENT=5
JOB_TIMEOUT_SECONDS=3600
JOB_MAX_RETRIES=3

# ============ SARVAM CONFIG ============
SARVAM_CHUNK_STT_ENABLED=true
SARVAM_CHUNK_SECONDS=25
SARVAM_BATCH_MAX_WAIT_SECONDS=120
SARVAM_BATCH_POLL_INTERVAL=5
SARVAM_BATCH_ABSOLUTE_MAX_SECONDS=3600
SARVAM_BATCH_BLOCKING_POLL_SECONDS=0
SARVAM_REST_MAX_SECONDS=30

# Sarvam API (required for Sarvam STT/LLM pipelines)
SARVAM_API_KEY=
SARVAM_STT_URL=https://api.sarvam.ai/speech-to-text
SARVAM_STT_MODEL=saaras:v3
SARVAM_STT_MODE=translate
SARVAM_STT_LANGUAGE=unknown
SARVAM_LLM_URL=https://api.sarvam.ai/v1/chat/completions
SARVAM_LLM_MODEL=sarvam-30b
SARVAM_LLM_PLAN_TIER=starter
SARVAM_LLM_MAX_TOKENS=2048
SARVAM_LLM_CONTEXT_WINDOW_TOKENS=8192
SARVAM_LLM_CONTENT_RETRIES=3
# none = disable Sarvam-30B internal reasoning (recommended for JSON analysis)
SARVAM_LLM_REASONING_EFFORT=none

# ============ AI GUARDRAILS ============
GUARDRAILS_MAX_TRANSCRIPT_CHARS=12000
GUARDRAILS_PII_MASKING_ENABLED=true

# ============ GROQ API ============
# Groq API (Whisper translate-to-English STT)
GROQ_API_KEY=
GROQ_STT_MODEL=whisper-large-v3

# ============ OPENROUTER API ============
# OpenRouter API (Gemma 4 26B LLM)
OPENROUTER_API_KEY=
OPENROUTER_LLM_MODEL=google/gemma-4-26b-a4b-it
OPENROUTER_LLM_URL=https://openrouter.ai/api/v1/chat/completions
OPENROUTER_APP_NAME=Call Analytics Lab

# ============ CORS ============
# Comma-separated list of allowed origins (add your Vercel URL in production)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
